# Copy to .env and adjust. Used by the production server (server/prod.ts).

# Port the Node server listens on (nginx proxies to this).
PORT=8080

# If set, POST /api/ingest requires:
#   Authorization: Bearer <token>   OR   x-api-key: <token>
# Accepts a single token OR a comma-separated list (any one is valid) — handy
# for rotating tokens or running multiple device batches:
#   INGEST_TOKEN=tokenA,tokenB
# Leave blank to keep the ingest endpoint open (not recommended in prod).
INGEST_TOKEN=

# Restrict which origin may call the API. Default "*".
CORS_ORIGIN=*

# Where state + users + auth secret are written (survives restarts/reboots).
FLEET_DATA_DIR=./data

# --- Auth ---
# Pin the session-signing secret (otherwise generated + stored in FLEET_DATA_DIR).
# AUTH_SECRET=

# Default admin seeded on first boot (only if no admin exists yet).
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=flextron-admin

# --- Frontend (build-time only) ---
# Point the dashboard at an external API instead of same-origin.
# Leave blank to use the bundled server above.
# VITE_API_BASE_URL=

# Google Maps. If set, the map uses the real Google basemap; otherwise it
# falls back to keyless OpenStreetMap. Create a key in Google Cloud Console
# with the "Maps JavaScript API" enabled.
# VITE_GOOGLE_MAPS_API_KEY=
# Optional cloud Map ID for custom styling (defaults to Google's DEMO_MAP_ID).
# VITE_GOOGLE_MAPS_MAP_ID=
